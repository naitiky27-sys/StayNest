<%- include('../partials/head') %>
    </head>

    <body class="bg-gray-100">

        <%- include('../partials/nav') %>

            <main class="max-w-7xl mx-auto px-6 py-10">


                <div class="bg-white rounded-3xl shadow-xl overflow-hidden">

                    <!-- Hero Image -->

                    <div class="relative group">

                        <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>"
                            class="w-full h-[550px] object-cover transition duration-700 group-hover:scale-105">

                        <!-- Dark Overlay -->

                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent">
                        </div>

                        <!-- Guest Favourite -->

                        <div
                            class="absolute top-6 left-6 bg-[#FF385C] text-white px-5 py-2 rounded-full shadow-lg font-semibold">

                            ❤️ Guest Favourite

                        </div>

                        <!-- Rating -->

                        <div
                            class="absolute top-6 right-6 bg-white rounded-xl shadow-lg px-5 py-3 flex items-center gap-2">

                            ⭐

                            <span class="font-bold text-lg">

                                <%= home.rating %>

                            </span>

                        </div>

                        <!-- Property Info -->

                        <div class="absolute bottom-10 left-10 text-white">

                            <h1 class="text-5xl font-extrabold drop-shadow-lg">

                                <%= home.houseName %>

                            </h1>

                            <div class="flex items-center gap-6 mt-4 text-lg">

                                <span>

                                    📍 <%= home.location %>

                                </span>

                                <span>

                                    🏡 Entire Home

                                </span>

                                <span>

                                    👥 4 Guests

                                </span>

                            </div>

                        </div>

                    </div>

                    <!-- Details -->

                    <div class="grid lg:grid-cols-3 gap-10 p-10">

                        <!-- Left Section -->

                        <div class="lg:col-span-2">

                            <!-- About -->

                            <section>

                                <h2 class="text-3xl font-bold text-gray-800">

                                    About this place

                                </h2>
                                <div class="-mt-8">

                                    <p class="mt-10 text-gray-600 leading-8 text-lg">

                                        <%= home.description %>

                                    </p>

                            </section>

                            <div class="lg:col-span-2 space-y-10">

                                <!-- About -->



                                <!-- Leave Review -->

                                <section class="bg-white rounded-3xl shadow-md border border-gray-100 p-8 mt-4">

                                    <div class="flex items-center justify-between mb-6">

                                        <h2 class="text-3xl font-bold text-gray-800">
                                            Leave a Review
                                        </h2>

                                        <span
                                            class="bg-[#FF385C] text-white px-4 py-2 rounded-full text-sm font-semibold">
                                            Share Your Experience
                                        </span>

                                    </div>

                                    <form action="/homes/<%= home._id %>/reviews" method="POST" class="space-y-6">

                                        <div>

                                            <label class="block font-semibold text-gray-700 mb-2">
                                                Rating
                                            </label>

                                            <select name="rating"
                                                class="w-full border border-gray-300 rounded-xl p-4 focus:ring-2 focus:ring-[#FF385C] focus:outline-none">

                                                <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
                                                <option value="4">⭐⭐⭐⭐ Very Good</option>
                                                <option value="3">⭐⭐⭐ Good</option>
                                                <option value="2">⭐⭐ Fair</option>
                                                <option value="1">⭐ Poor</option>

                                            </select>

                                        </div>

                                        <div>

                                            <label class="block font-semibold text-gray-700 mb-2">
                                                Comment
                                            </label>

                                            <textarea name="comment" rows="5"
                                                class="w-full border border-gray-300 rounded-xl p-4 resize-none focus:ring-2 focus:ring-[#FF385C] focus:outline-none"
                                                placeholder="Tell future guests about your stay..."></textarea>

                                        </div>

                                        <button type="submit"
                                            class="bg-[#FF385C] hover:bg-[#E31C5F] text-white px-8 py-4 rounded-xl font-semibold transition duration-300 shadow-lg">

                                            Submit Review

                                        </button>

                                    </form>

                                </section>

                                <!-- Reviews -->

                                <section class="bg-white rounded-3xl shadow-md border border-gray-100 p-8">

                                    <div class="flex justify-between items-center mb-8">

                                        <h2 class="text-3xl font-bold text-gray-800">
                                            Guest Reviews
                                        </h2>

                                        <span class="text-gray-500 font-medium">

                                            <%= home.reviews.length %> Reviews

                                        </span>

                                    </div>

                                    <% if(home.reviews.length===0){ %>

                                        <div class="text-center py-12">

                                            <div class="text-6xl mb-4">
                                                ⭐
                                            </div>

                                            <h3 class="text-2xl font-bold text-gray-700">
                                                No Reviews Yet
                                            </h3>

                                            <p class="text-gray-500 mt-2">
                                                Be the first guest to share your experience.
                                            </p>

                                        </div>

                                        <% } else { %>

                                            <div class="space-y-6">

                                                <% home.reviews.forEach(review=> { %>

                                                    <div
                                                        class="border border-gray-200 rounded-2xl p-6 hover:shadow-lg transition">

                                                        <div class="flex justify-between items-center">

                                                            <div class="flex items-center gap-4">

                                                                <div
                                                                    class="w-12 h-12 rounded-full bg-[#FF385C] text-white flex items-center justify-center font-bold text-lg">

                                                                    <%= review.username ?
                                                                        review.username.charAt(0).toUpperCase() : "U" %>

                                                                </div>

                                                                <div>

                                                                    <h3 class="font-bold text-lg">
                                                                        <%= review.username || "Anonymous User" %>
                                                                    </h3>

                                                                    <p class="text-gray-500 text-sm">
                                                                        Verified Guest
                                                                    </p>

                                                                </div>

                                                            </div>

                                                            <div
                                                                class="bg-yellow-100 text-yellow-700 px-4 py-2 rounded-full font-semibold">

                                                                ⭐ <%= review.rating %>/5

                                                            </div>

                                                        </div>

                                                        <p class="text-gray-600 leading-7 mt-5">

                                                            <%= review.comment %>

                                                        </p>

                                                    </div>

                                                    <% }) %>

                                            </div>

                                            <% } %>

                                </section>

                            </div>




                            <!-- Highlights -->

                            <section class="mt-10">

                                <h2 class="text-2xl font-bold text-gray-800 mb-6">

                                    Why you'll love this place

                                </h2>

                                <div class="grid sm:grid-cols-2 gap-5">

                                    <div class="bg-green-50 rounded-2xl p-5 border border-green-100">

                                        <div class="text-3xl">

                                            🏆

                                        </div>

                                        <h3 class="font-semibold mt-3">

                                            Top Rated Property

                                        </h3>

                                        <p class="text-gray-500 text-sm mt-1">

                                            Highly rated by previous guests.

                                        </p>

                                    </div>

                                    <div class="bg-blue-50 rounded-2xl p-5 border border-blue-100">

                                        <div class="text-3xl">

                                            📍

                                        </div>

                                        <h3 class="font-semibold mt-3">

                                            Prime Location

                                        </h3>

                                        <p class="text-gray-500 text-sm mt-1">

                                            Close to popular attractions.

                                        </p>

                                    </div>

                                    <div class="bg-yellow-50 rounded-2xl p-5 border border-yellow-100">

                                        <div class="text-3xl">

                                            ✨

                                        </div>

                                        <h3 class="font-semibold mt-3">

                                            Super Clean

                                        </h3>

                                        <p class="text-gray-500 text-sm mt-1">

                                            Professionally cleaned before every stay.

                                        </p>

                                    </div>

                                    <div class="bg-purple-50 rounded-2xl p-5 border border-purple-100">

                                        <div class="text-3xl">

                                            🛎️

                                        </div>

                                        <h3 class="font-semibold mt-3">

                                            24×7 Support

                                        </h3>

                                        <p class="text-gray-500 text-sm mt-1">

                                            Always available whenever you need help.

                                        </p>

                                    </div>

                                </div>

                            </section>

                            <!-- Amenities -->

                            <section class="mt-12">

                                <h2 class="text-2xl font-bold text-gray-800 mb-6">

                                    What this place offers

                                </h2>

                                <div class="flex flex-wrap gap-3">

                                    <span class="bg-gray-100 px-4 py-2 rounded-full">
                                        📶 Free WiFi
                                    </span>

                                    <span class="bg-gray-100 px-4 py-2 rounded-full">
                                        🏊 Swimming Pool
                                    </span>

                                    <span class="bg-gray-100 px-4 py-2 rounded-full">
                                        🍳 Breakfast Included
                                    </span>

                                    <span class="bg-gray-100 px-4 py-2 rounded-full">
                                        🚗 Free Parking
                                    </span>

                                    <span class="bg-gray-100 px-4 py-2 rounded-full">
                                        ❄ Air Conditioning
                                    </span>

                                    <span class="bg-gray-100 px-4 py-2 rounded-full">
                                        🛏 King Size Bed
                                    </span>

                                    <span class="bg-gray-100 px-4 py-2 rounded-full">
                                        📺 Smart TV
                                    </span>

                                    <span class="bg-gray-100 px-4 py-2 rounded-full">
