                                        </div>

                                    </div>
                                    <script src='https://api.mapbox.com/mapbox-gl-js/v3.1.0/mapbox-gl.js'></script>
                                    <link href='https://api.mapbox.com/mapbox-gl-js/v3.1.0/mapbox-gl.css'
                                        rel='stylesheet' />

                                    <div class="my-8 border-t pt-6">
                                        <h3 class="text-xl font-semibold mb-4 text-gray-800">Where you'll be</h3>
                                        <div id='map' class="w-full h-96 rounded-xl shadow-md border border-gray-200">
                                        </div>
                                    </div>



                                    <div class="mt-8">

                                        <h3 class="text-xl font-bold mb-4">

                                            Reserve your stay

                                        </h3>

                                        <%- include('../partials/bookings', { home: home, bookingError: bookingError })
                                            %>


                                    </div>

                                    <div class="mt-5">

                                        <%- include('../partials/favourite') %>

                                    </div>

                                    <!-- Benefits -->

                                    <div class="mt-8 space-y-3">

                                        <div class="flex items-center gap-3">

                                            ✅

                                            <span class="text-gray-600">

                                                Free Cancellation

                                            </span>

                                        </div>

                                        <div class="flex items-center gap-3">

                                            🛡️

                                            <span class="text-gray-600">

                                                Secure Booking

                                            </span>

                                        </div>

                                        <div class="flex items-center gap-3">

                                            💳

                                            <span class="text-gray-600">

                                                No Hidden Charges

                                            </span>

                                        </div>

                                        <div class="flex items-center gap-3">

                                            ⚡

                                            <span class="text-gray-600">

                                                Instant Confirmation

                                            </span>

                                        </div>

                                    </div>

                                    <!-- Price Details -->

                                    <div class="border-t mt-8 pt-6">

                                        <h3 class="font-bold text-lg mb-4">

                                            Price Details

                                        </h3>

                                        <div class="space-y-3">

                                            <div class="flex justify-between">

                                                <span class="text-gray-500">

                                                    ₹<%= home.price %> × 1 night

                                                </span>

                                                <span>

                                                    ₹<%= home.price %>

                                                </span>

                                            </div>

                                            <div class="flex justify-between">

                                                <span class="text-gray-500">

                                                    Cleaning Fee

                                                </span>

                                                <span>

                                                    ₹499

                                                </span>

                                            </div>

                                            <div class="flex justify-between">

                                                <span class="text-gray-500">

                                                    Service Fee

                                                </span>

                                                <span>

                                                    ₹299

                                                </span>

                                            </div>

                                        </div>

                                        <div class="border-t mt-6 pt-5 flex justify-between text-xl font-bold">

                                            <span>

                                                Total

                                            </span>

                                            <span class="text-[#FF385C]">

                                                ₹<%= home.price + 798 %>

                                            </span>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

            </main>

            <%- include('../partials/footer') %>

    </body>


    <%- include('../partials/footer') %>

        </body>
        <link href="https://api.mapbox.com/mapbox-gl-js/v3.1.0/mapbox-gl.css" rel="stylesheet" />
        <script src="https://api.mapbox.com/mapbox-gl-js/v3.1.0/mapbox-gl.js"></script>

        <div class="my-8 border-t pt-6">
            <h3 class="text-xl font-semibold mb-4 text-gray-800">Where you'll be</h3>
            <div id="map" style="width: 100%; height: 400px; background-color: #eee;"
                class="rounded-xl shadow-md border border-gray-200"></div>
        </div>

        <script>
            mapboxgl.accessToken = <% - JSON.stringify(mapboxToken) %>;

            // Values are pre-serialized server-side (see toScriptJSON in
            // storeController.js) so they can be embedded directly here
            // without risk of breaking out of the script tag.
            const coordinates = <% - mapCoordinatesJSON %>;
            const homeTitle = <% - homeTitleJSON %>;
            const homeAddress = <% - homeAddressJSON %>;

            let mapCenter = [77.2090, 28.6139];
            let validPin = false;

            if (coordinates && Array.isArray(coordinates) && coordinates.length === 2) {
                mapCenter = [parseFloat(coordinates[0]), parseFloat(coordinates[1])];
                validPin = true;
            }

            try {
                const map = new mapboxgl.Map({
                    container: 'map',
                    style: 'mapbox://styles/mapbox/streets-v12',
                    center: mapCenter,
                    zoom: validPin ? 14 : 11
                });

                map.addControl(new mapboxgl.NavigationControl(), 'top-right');

                if (validPin) {
                    new mapboxgl.Marker({ color: '#FF385C' })
                        .setLngLat(mapCenter)
                        .setPopup(
                            new mapboxgl.Popup({ offset: 25 })
                                .setHTML(`<h4 style="font-weight: bold; font-size: 14px;">${homeTitle}</h4><p style="font-size: 12px; color: #666;">${homeAddress}</p>`)
                        )
                        .addTo(map)
                        .togglePopup();
                }
            } catch (error) {
                console.error("Mapbox error:", error);
            }
        </script>


        </html>