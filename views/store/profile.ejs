<%- include('../partials/head') %>
</head>

<body class="bg-gray-100">

<%- include('../partials/nav') %>

<div class="bg-gradient-to-r from-[#FF385C] to-pink-500 rounded-3xl p-10 text-white shadow-xl">

    <div class="flex flex-col items-center">

        <div class="w-32 h-32 rounded-full bg-white text-[#FF385C] flex items-center justify-center text-6xl shadow-lg border-4 border-white">

            👤

        </div>

        <h1 class="text-4xl font-bold mt-5">
            <%= user.firstName %>
        </h1>

        <p class="mt-2 opacity-90">
            <%= user.email %>
        </p>

        <span class="mt-4 bg-white text-[#FF385C] px-5 py-2 rounded-full font-semibold">

            <%= user.userType.toUpperCase() %>

        </span>

    </div>

</div>
<div class="bg-white rounded-2xl shadow-lg mt-8 p-8">

    <h2 class="text-2xl font-bold mb-8">

        Personal Information

    </h2>

    <div class="grid md:grid-cols-2 gap-6">

        <div>

            <p class="text-gray-500">

                Full Name

            </p>

            <h3 class="text-lg font-semibold">

                <%= user.firstName %>

            </h3>

        </div>

        <div>

            <p class="text-gray-500">

                Email

            </p>

            <h3 class="text-lg font-semibold">

                <%= user.email %>

            </h3>

        </div>

        <div>

            <p class="text-gray-500">

                Account Type

            </p>

            <h3 class="text-lg font-semibold">

                <%= user.userType %>

            </h3>

        </div>

    </div>

</div>
<div class="flex justify-center gap-6 mt-10">

    <a
        href="/profile/edit"
        class="bg-[#FF385C] text-white px-8 py-3 rounded-xl font-semibold hover:bg-[#E31C5F] transition shadow-lg">

        ✏ Edit Profile

    </a>

    <a
        href="/change-password"
        class="border-2 border-[#FF385C] text-[#FF385C] px-8 py-3 rounded-xl font-semibold hover:bg-[#FF385C] hover:text-white transition">

        🔒 Change Password

    </a>

</div>

<%- include('../partials/footer') %>