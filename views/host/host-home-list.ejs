<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="max-w-7xl mx-auto px-6 py-10">
        

    <div class="text-center mb-10">
        <h2 class="text-5xl font-extrabold text-gray-800">
            Hey Host 👋
        </h2>

        <p class="text-gray-500 mt-2 text-lg">
            Manage all your listed properties
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-10">

        <% registeredHomes.forEach(home => { %>

        <div
            class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl hover:-translate-y-2 transition duration-300">

            <!-- Image -->

            <div class="relative">

                <img
                    src="<%= home.photoUrl %>"
                    alt="<%= home.houseName %>"
                    class="w-full h-64 object-cover">

                <span
                    class="absolute top-4 left-4 bg-white px-3 py-1 rounded-full text-xs font-bold shadow">
                    Guest Favourite
                </span>

                <button
                    class="absolute top-4 right-4 bg-white p-2 rounded-full shadow hover:bg-red-100">

                    ❤️

                </button>

            </div>

            <!-- Content -->

            <div class="p-6">

                <div class="flex justify-between items-start">

                    <h3 class="text-2xl font-bold text-gray-800">
                        <%= home.houseName %>
                    </h3>

                    <div class="flex items-center">

                        ⭐

                        <span class="ml-1 font-semibold">
                            <%= home.rating %>
                        </span>

                    </div>

                </div>

                <div class="flex items-center mt-3 text-gray-500">

                    📍

                    <span class="ml-2">
                        <%= home.location %>
                    </span>

                </div>

                <div class="mt-5">

                    <span class="text-2xl font-bold text-[#FF385C]">

                        ₹<%= home.price %>

                    </span>

                    <span class="text-gray-500">
                        / night
                    </span>

                </div>

                <div class="flex gap-4 mt-6">

                    <a
                        href="/host/edit-home/<%=home._id%>?editing=true"
                        class="flex-1 text-center bg-blue-500 hover:bg-blue-600 text-white py-3 rounded-xl font-semibold transition">

                        ✏ Edit

                    </a>

                    <form
                        action="/host/delete-home/<%= home._id %>"
                        method="POST"
                        class="flex-1">

                        <button
                            type="submit"
                            class="w-full bg-red-500 hover:bg-red-600 text-white py-3 rounded-xl font-semibold transition">

                            🗑 Delete

                        </button>

                    </form>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</main>
<%- include('../partials/footer') %>
  </body>
</html>